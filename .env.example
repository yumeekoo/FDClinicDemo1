# ============================================================================
# Environment variables template — copy to one of:
#   .env.local        -> local development
#   .env.test         -> testing/staging Supabase project (branch: develop)
#   .env.production   -> production Supabase project (branch: main)
#
# On Vercel, set these under Settings > Environment Variables and scope them:
#   Production values  -> [Production]
#   Testing values     -> [Preview] + [Development]
# Do NOT commit the real .env.* files (only this .env.example is committed).
# ============================================================================

# --- Supabase API (from Supabase Dashboard > Settings > API) ---------------
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Server-only — bypasses Row Level Security. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- Database (from Supabase Dashboard > Settings > Database) ---------------
# Runtime app connection — use the Transaction pooler (port 6543).
DATABASE_URL="postgresql://postgres.<ref>:<password>@<host>:6543/postgres"

# Migrations (drizzle-kit) — use the Direct/Session connection (port 5432).
DIRECT_URL="postgresql://postgres.<ref>:<password>@<host>:5432/postgres"
